# ─────────────────────────────────────────
.env
*.env
niblit_params.json
niblit_lean_signal.json

# ─────────────────────────────────────────
# Runtime / AI memory (Niblit)
# ─────────────────────────────────────────
data/
niblit/

# JSON runtime state (NOT configs)
*_state.json
*.jsonl
niblit_*.json

# Pickle / memory graphs
*.pkl

# Virtual environments
.venv/
niblit-env/

# Python deep cache
**/__pycache__/

