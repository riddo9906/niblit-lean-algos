# ──────────────────────────────────────────────────────────────────────────────
# niblit-lean-algos — required environment variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── QuantConnect credentials (required for deployment & backtesting) ──────────
# Your numeric QuantConnect user ID (found at quantconnect.com → Account)
QC_USER_ID=

# Your QuantConnect API token (found at quantconnect.com → Account → API)
QC_API_CRED=

# ── Niblit AI signal bridge (required for the AI Master algorithm) ────────────
# Absolute path to the Niblit trading-brain signal file.
# Niblit writes this file; the LEAN AI Master algorithm reads it.
# Default (if not set): /tmp/niblit_lean_signal.json
NIBLIT_SIGNAL_FILE=/tmp/niblit_lean_signal.json

# Maximum age of a signal before it is considered stale (seconds).
# Default: 300 (5 minutes)
NIBLIT_SIGNAL_MAX_AGE=300

# ── Algorithm symbol override ─────────────────────────────────────────────────
# Symbol for the AI Master algorithm (20_niblit_ai_master).
# Supported: SPY, AAPL, BTCUSD, ETHUSD, etc.
# Default: SPY
NIBLIT_SYMBOL=SPY

# ── GitHub (required for nibblebot workflows) ─────────────────────────────────
# Set automatically in GitHub Actions — only needed for local testing.
# GITHUB_TOKEN=ghp_...

# Enable GitHub Models LLM-enhanced reports (optional).
# Requires GITHUB_MODELS_TOKEN or PAT with models:read scope.
# GITHUB_MODELS_TOKEN=ghp_...
# USE_GH_MODEL_REPORTS=false
