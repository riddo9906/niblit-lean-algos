# ──────────────────────────────────────────────────────────────────────────────
# niblit-lean-algos — required environment variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Freqtrade / Binance (primary — replace QuantConnect) ─────────────────────
# Binance exchange API credentials (required for live trading with Freqtrade).
# Create keys at https://www.binance.com/en/my/settings/api-management
# Give "Enable Spot & Margin Trading" permission; DO NOT enable withdrawals.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Freqtrade REST API server credentials (for ft_live.py status/control)
FT_API_HOST=127.0.0.1
FT_API_PORT=8080
FT_API_USER=freqtrader
FT_API_PASS=

# Telegram notifications (optional — configure in configs/freqtrade_config_*.json)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Niblit AI signal bridge ────────────────────────────────────────────────────
# Absolute path to the Niblit trading-brain signal file.
# Niblit writes this file; Freqtrade strategies read it.
# Default (if not set): /tmp/niblit_lean_signal.json
NIBLIT_SIGNAL_FILE=/tmp/niblit_lean_signal.json

# Maximum age of a signal before it is considered stale (seconds).
# Default: 300 (5 minutes)
NIBLIT_SIGNAL_MAX_AGE=300

# Minimum Niblit confidence to trigger an entry veto (0.0–1.0).
# Default: 0.55
NIBLIT_MIN_CONF=0.55

# Path for Freqtrade AI Master results JSON (read back by Niblit).
# Default: /tmp/niblit_ft_results.json
NIBLIT_RESULTS_FILE=/tmp/niblit_ft_results.json

# Trade reflection and market-memory event streams (JSONL append files).
NIBLIT_REFLECTION_FILE=/tmp/niblit_trade_reflection.jsonl
NIBLIT_EPISODES_FILE=/tmp/niblit_market_episodes.jsonl

# Governance gate coherence thresholds.
NIBLIT_SURVIVAL_COHERENCE=0.30
NIBLIT_CONSTRAINED_COHERENCE=0.45
NIBLIT_MIN_HEALTH_MULTIPLIER=0.05

# ── GitHub (required for nibblebot workflows) ─────────────────────────────────
# Set automatically in GitHub Actions — only needed for local testing.
# GITHUB_TOKEN=ghp_...

# Enable GitHub Models LLM-enhanced reports (optional).
# GITHUB_MODELS_TOKEN=ghp_...
# USE_GH_MODEL_REPORTS=false

# ── LEGACY: QuantConnect credentials (deprecated — kept for existing QC algos) ─
# QC_USER_ID=
# QC_API_CRED=

# ── LEGACY: QuantConnect algorithm overrides ──────────────────────────────────
# NIBLIT_SYMBOL=SPY
# NIBLIT_FOREX_PAIRS=EURUSD,GBPUSD,USDJPY,AUDUSD,USDCAD
# NIBLIT_SA_SYMBOL=SPY
# NIBLIT_SA_META_FILE=/tmp/niblit_self_aware_state.json
